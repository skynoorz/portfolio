# EmailJS configuration for the contact form.
# Create a free account at https://www.emailjs.com/ and copy your IDs here.
# Then rename this file to ".env" (it is git-ignored).
#
# If these are left empty the form falls back to opening the user's email client
# via a mailto: link, so the site still works without any configuration.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional: override the GitHub Pages base path at build time.
# Example for a repo named "portfolio-ronald":
# VITE_BASE=/portfolio-ronald/
